{
  "name": "medstart-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "MedStart — Enterprise Hospital Finder & Navigation Platform",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:server": "npm run dev --workspace=apps/server",
    "build:web": "npm run build --workspace=apps/web",
    "build:server": "npm run build --workspace=apps/server",
    "build": "npm run build:web",
    "start:web": "npm run start --workspace=apps/web",
    "start:server": "npm run start --workspace=apps/server",
    "lint": "npm run lint --workspace=apps/web",
    "test": "npm run test --workspace=apps/web"
  },
  "keywords": [
    "healthcare",
    "hospital-finder",
    "navigation",
    "leaflet",
    "pwa",
    "nextjs",
    "firebase"
  ],
  "author": "MedStart Engineering Team",
  "license": "MIT"
}
